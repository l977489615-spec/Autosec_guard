AUTOSEC_SECRET_KEY=replace_with_a_long_random_secret
AUTOSEC_DB_URI=sqlite:///server/autosec.db
AUTOSEC_API=http://localhost:5002
MCP_SERVER=http://localhost:5003
AUTOSEC_HOST=0.0.0.0
AUTOSEC_PORT=5002
AUTOSEC_DEBUG=false
# Optional for packaged edge workstation releases. If unset, packaged builds use
# the OS user data directory; source-mode development keeps server/autosec.db.
# AUTOSEC_DATA_DIR=/opt/autosec-guard-edge/data
# Local edge workstation mode is the default product mode.
